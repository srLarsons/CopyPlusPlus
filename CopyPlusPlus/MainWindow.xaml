<Window x:Class="WpfMultiCopyClipboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Multi Copy Clipboard" Height="450" Width="720"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Multi Copy Clipboard" />
            <TextBlock Margin="0,6,0,0" TextWrapping="Wrap">
                Press Ctrl+C twice quickly to add the selected content to this list. Press Ctrl+V twice quickly to paste everything together.
            </TextBlock>
        </StackPanel>

        <ListBox Grid.Row="1" ItemsSource="{Binding Items}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8" Margin="0,4" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                            <TextBlock Margin="0,3,0,0" Text="{Binding Preview}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="120" Margin="0,0,8,0" Content="Clear List" Click="Clear_Click" />
            <Button Width="150" Content="Paste All Now" Click="PasteAll_Click" />
        </StackPanel>
    </Grid>
</Window>
