<Window x:Class="WpfMultiCopyClipboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="copy++ - Multi Copy Clipboard" Height="450" Width="720"
        Icon="Assets/copyplusplus-logo.ico"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ContextMenu>
            <ContextMenu Opened="ClipboardContextMenu_Opened">
                <MenuItem Header="Paste All" Click="PasteAll_Click" />
                <MenuItem x:Name="PasteMenuItem" Header="Paste" />
                <MenuItem x:Name="DeleteMenuItem" Header="Delete Item" />
                <Separator />
                <MenuItem Header="Clear List" Click="Clear_Click" />
            </ContextMenu>
        </Grid.ContextMenu>

        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="True">
            <Border DockPanel.Dock="Left"
                    Width="54"
                    Height="54"
                    Margin="0,0,12,0"
                    Background="#111111"
                    CornerRadius="8">
                <Image Source="Assets/copyplusplus-logo.png"
                       Width="44"
                       Height="44"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Stretch="Uniform" />
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Multi Copy Clipboard" />
                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap">
                    Press Ctrl+Alt+C to save the selected content. Press Ctrl+Alt+V to paste everything.
                </TextBlock>
            </StackPanel>
        </DockPanel>

        <ListBox Grid.Row="1" ItemsSource="{Binding Items}" MouseDoubleClick="ItemsList_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8" Margin="0,4" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6">
                        <Border.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Paste"
                                          Click="PasteListItem_Click"
                                          CommandParameter="{Binding}" />
                                <MenuItem Header="Delete"
                                          Click="DeleteListItem_Click"
                                          CommandParameter="{Binding}" />
                            </ContextMenu>
                        </Border.ContextMenu>
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                            <TextBlock Margin="0,3,0,0" Text="{Binding Preview}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="120" Margin="0,0,8,0" Content="Clear List" Click="Clear_Click" />
            <Button Width="150" Content="Paste All Now" Click="PasteAll_Click" />
        </StackPanel>
    </Grid>
</Window>
